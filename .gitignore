# Solutions (instructor-only, never commit)
**/solution/
**/_apprentices-only/

# Node.js
node_modules/
.pnpm-store/
dist/
build/
.cache/

# Vite
*.local
.vite/

# Environment variables
.env
.env.local
.env.*.local

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# TypeScript
*.tsbuildinfo
